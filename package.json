{
  "name": "@polar-sh/sdk",
  "version": "0.46.4",
  "author": "Speakeasy",
  "type": "module",
  "tshy": {
    "sourceDialects": [
      "@polar-sh/sdk/source"
    ],
    "exports": {
      ".": "./src/index.ts",
      "./package.json": "./package.json",
      "./*.js": "./src/*.ts",
      "./*": "./src/*.ts"
    }
  },
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/polarsource/polar-js.git"
  },
  "scripts": {
    "lint": "eslint --cache --max-warnings=0 src",
    "build": "tshy",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    
  },
  "devDependencies": {
    "@eslint/js": "^9.26.0",
    "@types/jest": "*",
    "@types/node": "*",
    "eslint": "^9.26.0",
    "globals": "^15.14.0",
    "jest": "*",
    "ts-jest": "*",
    "tshy": "^3.3.2",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.26.0"
  },
  "dependencies": {
    "standardwebhooks": "^1.0.0",
    "zod": "^3.25.65 || ^4.0.0"
  }
}
